#!/usr/bin/env python3

"""
Galliard launcher script

This script checks for dependencies and launches Galliard
"""

import sys
import os
import importlib.util
import subprocess

def check_dependencies():
    """Check if required dependencies are installed"""
    # Required dependencies
    required = ["gi", "mpd"]
    missing = []

    # Check for each dependency
    for dep in required:
        if not importlib.util.find_spec(dep):
            missing.append(dep)

    # Handle missing dependencies
    if missing:
        print("Missing dependencies:", ", ".join(missing))
        print("Please install them with:")

        if "gi" in missing:
            print("  sudo apt-get install python3-gi python3-gi-cairo gir1.2-gtk-4.0 gir1.2-adw-1 gir1.2-notify-0.7")

        if "mpd" in missing:
            print("  pip3 install python-mpd2")

        return False

    return True

def main():
    """Main function"""
    # Check dependencies
    if not check_dependencies():
        return 1

    # Add the project directory to Python path if running from source
    current_dir = os.path.dirname(os.path.abspath(__file__))
    project_dir = os.path.dirname(current_dir)
    sys.path.insert(0, project_dir)
    sys.path.insert(0, os.path.join(project_dir, "galliard"))

    # Import and run the application
    from galliard import __main__
    return __main__.main()

if __name__ == "__main__":
    sys.exit(main())
