# Minimal image for deterministic full-pyramid test runs.
#
# Ships the Fedora packages galliard actually depends on at runtime
# (PyGObject + gtk4 + libadwaita + mpd) plus pytest, Xvfb, and python-
# snapcast. Run via ``./tests/run-in-container.sh``.

FROM registry.fedoraproject.org/fedora:latest

# mpd lives in RPM Fusion (free); the rest are in the main Fedora repos.
RUN dnf -y install \
        "https://mirrors.rpmfusion.org/free/fedora/rpmfusion-free-release-$(rpm -E %fedora).noarch.rpm" \
    && dnf -y install \
        python3 \
        python3-pip \
        python3-gobject \
        gtk4 \
        libadwaita \
        mpd \
        xorg-x11-server-Xvfb \
        python3-mpd2 \
        python3-pyxdg \
        python3-pytest \
        python3-pytest-asyncio \
        python3-pytest-cov \
    && dnf clean all

# python-snapcast isn't packaged in Fedora's repos; PEP 668 wants us to
# stay out of the system site-packages, but inside a disposable image
# that's the whole point.
RUN pip install --no-cache-dir --break-system-packages snapcast

WORKDIR /workspace

ENV DISPLAY=:99

CMD ["sh", "-c", "Xvfb :99 -screen 0 1024x768x24 & sleep 0.3; exec pytest -v"]
